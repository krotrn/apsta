#!/usr/bin/env python3
"""Thin launcher for apsta GTK app.

Keeps the historical gtk-ui/apsta-gtk entrypoint while sharing one codebase.
"""

import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from apsta_gui.app import main


if __name__ == "__main__":
    main()
