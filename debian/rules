#!/usr/bin/make -f

export PYBUILD_NAME=apsta
export HOME := $(CURDIR)/debian/.home
export CARGO_HOME := $(CURDIR)/debian/.cargo

%:
	dh $@ --with python3

override_dh_auto_build:
	dh_auto_build
	# Build COSMIC applet from vendored dependencies only (no network).
	cargo build --release --locked --frozen --offline --manifest-path cosmic-applet-apsta/Cargo.toml

override_dh_install:
	# Install apsta CLI
	install -Dm755 apsta.py debian/apsta/usr/bin/apsta
	install -Dm644 system/apsta.service debian/apsta/lib/systemd/system/apsta.service
	install -Dm755 system/apsta-sleep debian/apsta/usr/lib/systemd/system-sleep/apsta-sleep

	# Install apsta-gtk GUI
	install -Dm755 gtk-ui/apsta-gtk debian/apsta/usr/bin/apsta-gtk
	install -Dm644 gtk-ui/com.github.apsta.Gtk.desktop debian/apsta/usr/share/applications/com.github.apsta.Gtk.desktop

	# Install COSMIC applet binary + desktop entry.
	install -Dm755 cosmic-applet-apsta/target/release/cosmic-applet-apsta debian/apsta/usr/bin/cosmic-applet-apsta
	install -Dm644 cosmic-applet-apsta/data/com.github.apsta.Applet.desktop debian/apsta/usr/share/applications/com.github.apsta.Applet.desktop