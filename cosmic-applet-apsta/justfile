# cosmic-applet-apsta justfile
# Matches conventions used by all official COSMIC applets.

name    := "cosmic-applet-apsta"
prefix  := env_var_or_default("prefix", "/usr")
bindir  := prefix + "/bin"
datadir := prefix + "/share"

# Default: build release
default: build-release

# Build debug
build:
    cargo build

# Build release
build-release:
    cargo build --release

# Install binary + desktop entry (builds first if needed)
install: build-release
    install -Dm755 target/release/{{name}} {{bindir}}/{{name}}
    install -Dm644 data/com.github.apsta.Applet.desktop \
        {{datadir}}/applications/com.github.apsta.Applet.desktop
    @echo "Installed. Add 'apsta Hotspot' in COSMIC Settings → Desktop → Panel."

# Uninstall
uninstall:
    rm -f {{bindir}}/{{name}}
    rm -f {{datadir}}/applications/com.github.apsta.Applet.desktop

# Run in development (requires COSMIC session)
run:
    cargo run

# Clean
clean:
    cargo clean
